{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/**/*.worker.ts"],
  "compilerOptions": {
    "lib": ["ESNext", "WebWorker"],
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worker.tsbuildinfo"
  }
}
